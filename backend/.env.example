# Vantage Backend Configuration
# Copy this file to .env and adjust values as needed.
# All settings are optional — the defaults work for a standard local setup.

# Port the backend listens on (default: 8001)
# VANTAGE_PORT=8001

# Directory where nodes.json, aliases.json, history.json and vantage.log are stored.
# Default is ../data relative to the backend directory.
# VANTAGE_DATA_DIR=../data

# Allowed frontend origin for CORS. Change if you run the frontend on a custom port.
# VANTAGE_FRONTEND_ORIGIN=http://localhost:5173

# Seconds of silence before a device is considered offline (default: 25)
# VANTAGE_STALE_THRESHOLD=25

# Seconds between automatic background re-scans (default: 300 = 5 min)
# VANTAGE_SCAN_INTERVAL=300

# Minimum seconds between manual /scan requests (default: 30)
# VANTAGE_SCAN_COOLDOWN=30
